# ─── SecureMessenger Backend — Environment Configuration ──────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong random secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-with-secrets-token-hex-32

# JWT algorithm (HS256 is fine for symmetric; use RS256 for asymmetric)
ALGORITHM=HS256

# Access token lifetime in minutes (keep short — 15 min recommended)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token lifetime in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Anti-Replay ───────────────────────────────────────────────────────────────
# How long (seconds) to remember used nonces (10 min matches token window)
NONCE_TTL_SECONDS=600

# Maximum allowed clock skew between client and server (±5 min)
TIMESTAMP_TOLERANCE_SECONDS=300

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./secure_messenger.db

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=SecureMessenger API

# Set to true to enable /docs, /redoc, and verbose logging
DEBUG=true

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON-formatted list. Restrict to your mobile app origin in production.
ALLOWED_ORIGINS=["*"]
